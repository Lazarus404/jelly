// bytes + numeric in templates: F16, F32, F64, i8, i16, i32, i64
let a: F16 = 1.1;
let b: F32 = 1.2;
let c: F64 = 1.3;
let d: i8 = 1;
let e: i16 = 2;
let f: i32 = 3;
let g: i64 = 4;
let z = `result: ${a + b + c + d + e + f + g}`;
// Sum = 1.1 + 1.2 + 1.3 + 1 + 2 + 3 + 4 = 12.6
System.assert(Bytes.len(z) > 0);
System.assert(Bytes.get_u8(z, 0) == 114); // 'r'
System.assert(Bytes.get_u8(z, 1) == 101); // 'e'
"ok"
