// ConstFun for method refs: prototype with direct fn literal; o.get() uses ConstFun.
let init: (Object, I32) -> Object = fn(self, n) {
  self.n = n;
  return self;
};

let get: (Object) -> I32 = fn(self) {
  return self.n;
};

prototype P {
  init: init;
  get: get;
};

let o: P = new P(7);
let h: I32 = o.get();
let r = if (h == 7) { "ok" } else { "bad" };
System.assert(r == "ok");
r
